// Prisma Schema — refill-list
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// Auth (RL-01, RL-19)
// ──────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships   HouseholdMember[]
  changedItems  Item[]           @relation("ItemLastChangedBy")
  createdItems  Item[]           @relation("ItemCreatedBy")
  historyEvents ShoppingHistory[]
}

// ──────────────────────────────────────────────
// Haushalt (RL-01, RL-19)
// ──────────────────────────────────────────────

model Household {
  id               String   @id @default(cuid())
  name             String
  reminderSettings Json?    // z.B. { enabled: true, time: "08:00" }
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  members    HouseholdMember[]
  invites    HouseholdInvite[]
  items      Item[]
  categories Category[]
  history    ShoppingHistory[]
}

model HouseholdMember {
  id          String                @id @default(cuid())
  role        HouseholdRole         @default(MEMBER)
  status      HouseholdMemberStatus @default(ACTIVE)
  joinedAt    DateTime              @default(now())

  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([householdId, userId])
}

model HouseholdInvite {
  id          String    @id @default(cuid())
  token       String    @unique @default(cuid())
  expiresAt   DateTime
  usedAt      DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
}

enum HouseholdRole {
  OWNER
  MEMBER
}

enum HouseholdMemberStatus {
  ACTIVE
  REMOVED
}

// ──────────────────────────────────────────────
// Artikel & Kategorien (RL-02, RL-03, RL-07, RL-20)
// ──────────────────────────────────────────────

model Item {
  id              String   @id @default(cuid())
  name            String
  normalizedName  String   // RL-20: lowercase, getrimmt
  canonicalItemId String?  // RL-20: Alias-Verknüpfung
  status          ItemStatus      @default(OK)
  isStandard      Boolean         @default(false)  // RL-03
  frequencyScore  Int             @default(0)       // RL-04: 0–100
  // RL-11: Zyklusmodell
  avgCycleDays        Int?
  cycleConfidence     CycleConfidence @default(NONE)
  nextPredictedEmpty  DateTime?
  // RL-21: Item-Lifecycle
  itemState       ItemState       @default(AVAILABLE)
  // Metadaten
  note            String?
  quantity        Int             @default(1)
  unit            String?
  priorityOverride      Boolean  @default(false)   // RL-14
  priorityOverrideUntil DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  householdId     String
  household       Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  categoryId      String?
  category        Category? @relation(fields: [categoryId], references: [id])

  createdById     String?
  createdBy       User?     @relation("ItemCreatedBy", fields: [createdById], references: [id])

  lastChangedById String?
  lastChangedBy   User?     @relation("ItemLastChangedBy", fields: [lastChangedById], references: [id])

  history         ShoppingHistory[]

  @@index([householdId, status])
  @@index([householdId, isStandard])
  @@index([normalizedName])
}

model Category {
  id                String   @id @default(cuid())
  name              String
  color             String?  // Hex
  fallbackCycleDays Int      @default(21) // RL-11
  createdAt         DateTime @default(now())

  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  items       Item[]

  @@unique([householdId, name])
}

enum ItemStatus {
  OK
  LOW
  EMPTY
}

enum ItemState {
  AVAILABLE
  PLANNED
  PURCHASED
  ARCHIVED
}

enum CycleConfidence {
  NONE
  LOW
  MEDIUM
  HIGH
}

// ──────────────────────────────────────────────
// Kaufhistorie (RL-10)
// ──────────────────────────────────────────────

model ShoppingHistory {
  id        String           @id @default(cuid())
  eventType HistoryEventType
  source    CaptureSource    @default(APP) // RL-16
  itemName  String           // snapshot: Name zum Zeitpunkt des Events
  createdAt DateTime         @default(now())

  householdId   String
  household     Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  itemId        String
  item          Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)

  triggeredById String?
  triggeredBy   User?     @relation(fields: [triggeredById], references: [id])

  @@index([householdId, createdAt])
  @@index([itemId, eventType])
}

enum HistoryEventType {
  MARKED_LOW
  MARKED_EMPTY
  MARKED_OK
  PURCHASED
  SUGGESTION_ACCEPTED
  SUGGESTION_DISMISSED
}

enum CaptureSource {
  APP
  SHARE
  DEEPLINK
  VOICE
  WIDGET
}
